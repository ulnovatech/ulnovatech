# UlnoVaTech CRM (ulndash) — copy to ulndash/backend/.env

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ulnovatech
DB_USER=root
DB_PASS=

APP_DEBUG=true
API_BASE=/api

# Comma-separated allowed browser origins (no wildcard in production)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5177,http://localhost:3000,http://localhost/ulnovatech,https://ulnovatech.store

# Dashboard login (required in production)
DASH_ADMIN_USER=admin
# Local dev only — use DASH_ADMIN_PASS_HASH in production
DASH_ADMIN_PASS=changeme
# DASH_ADMIN_PASS_HASH=

# Google Analytics service account (path relative to ulndash/backend)
GA_PROPERTY_ID=502536992
GA_CREDENTIALS_PATH=service-account.json

# Mobile admin app JWT (required in production)
MOBILE_JWT_SECRET=

# Firebase Cloud Messaging (FCM HTTP v1)
# Use the Firebase/GCP service account JSON with Firebase Cloud Messaging API enabled
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=service-account.json
# Falls back to GA_CREDENTIALS_PATH when FCM_CREDENTIALS_PATH is unset

