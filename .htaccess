RewriteEngine On

# Legacy HTML → React routes
RewriteRule ^about\.html$ /about [R=301,L]
RewriteRule ^prices\.html$ /prices [R=301,L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# CRM API → ulndash PHP backend
RewriteRule ^api/(.*)$ ulndash/backend/$1 [L]

# Marketing SPA fallback (preserve sub-apps and static handlers)
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/php/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/forms/
RewriteCond %{REQUEST_URI} !^/blog/
RewriteCond %{REQUEST_URI} !^/dash/
RewriteCond %{REQUEST_URI} !^/portfolio-app/
RewriteCond %{REQUEST_URI} !^/portfolio/
RewriteCond %{REQUEST_URI} !^/ulndash/
RewriteRule ^ index.html [L]

DirectoryIndex index.html
