{
  "name": "ulnova-admin-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "build:apk": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "build:apk:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease",
    "build:apk:check": "node scripts/check-android-env.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.4.2",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "ulnovatech-system": "file:.."
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.3.5",
    "vite": "^8.1.1"
  }
}
