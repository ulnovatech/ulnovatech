# Ulnova Admin Mobile — environment reference
# Copy values into .env.development (browser dev) or .env.production (APK build).
# Vite bakes .env.production into release APKs at build time.

# --- Browser dev (npm run dev) ---
# Proxied to XAMPP via vite.config.js
VITE_API_URL=/api
VITE_APACHE_BASE=http://localhost/ulnovatech
VITE_PORT=5177

# --- Production APK (npm run build:apk / build:apk:release) ---
# Public server (default):
# VITE_API_URL=https://ulnovatech.store/api

# Physical device testing against local XAMPP on your LAN:
# 1. Find your PC LAN IP: ipconfig  →  IPv4 Address (e.g. 192.168.1.42)
# 2. Ensure phone and PC are on the same Wi‑Fi
# 3. Set before building the APK:
# VITE_API_URL=http://192.168.1.42/ulnovatech/api
#
# Tip: use .env.production.local (gitignored) to override without editing tracked .env.production
