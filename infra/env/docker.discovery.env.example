# Docker Compose env — copy to docker.discovery.env (gitignored) before production use
# Used by discovery-web, discovery-worker, and discovery-migrate

# --- Postgres (must match postgres service in docker-compose.discovery.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=discovery_dev_change_me
POSTGRES_DB=agency_platform
DATABASE_URL=postgresql://postgres:discovery_dev_change_me@postgres:5432/agency_platform

# --- App ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local Docker: enable dev auth when Clerk keys are not configured yet.
# Set false before production cutover (requires CLERK_* keys below).
ALLOW_DEV_AUTH=true

# Worker handles pipeline jobs — do not enable inline pipeline in production.
# INLINE_PIPELINE=

# --- Storage (volume mounted at /app/storage/uploads in containers) ---
STORAGE_LOCAL_PATH=/app/storage/uploads

# --- Acquisition mode & budget caps (or edit in Settings UI) ---
ACQUISITION_MODE=standard
PLACES_MONTHLY_CAP=150
CSE_DAILY_CAP=100
BING_DAILY_CAP=50
META_GRAPH_DAILY_CAP=50
BROWSER_DAILY_CAP=10
CUSTOM_SCRAPE_DAILY_CAP=50

# --- Optional feature flags ---
# BROWSER_AUTOMATION_ENABLED=true
# CUSTOM_SCRAPE_ENABLED=true

# --- Optional: API key env fallbacks (prefer Settings UI) ---
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_API_KEYS=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# BING_SEARCH_KEY=
# META_GRAPH_API_TOKEN=

# --- Auth (production) ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/ops
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/ops

# --- Observability (optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Cron (production HTTP polls) ---
CRON_SECRET=

# --- Gmail OAuth (optional) ---
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
