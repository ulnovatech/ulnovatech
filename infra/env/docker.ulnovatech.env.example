# Docker Compose env — copy to docker.ulnovatech.env (gitignored) before `docker compose up`
# Mounted into public_html/php/.env and public_html/ulndash/backend/.env
#
# Production (Oracle VM):
#   cp docker.ulnovatech.env.example docker.ulnovatech.env
#   Place secrets under /opt/ulnovatech/secrets/ (see infra/env/README.md)

# --- Shared MySQL (php + ulndash) ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ulnovatech
DB_USER=ulnovatech
DB_PASS=ulnovatech_dev_change_me

# Public site URL (forms, redirects, Flutterwave callbacks)
# Local:  http://localhost:8080
# Prod (no custom domain yet): http://hub.34.66.94.12.nip.io  (see docs/ACCESS.md)
BASE_URL=http://localhost:8080

# --- ulndash CRM ---
APP_DEBUG=true
API_BASE=/api/
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5174,http://localhost:5177,http://127.0.0.1:8080
# Production example (temporary nip.io access):
# APP_DEBUG=false
# ALLOWED_ORIGINS=http://hub.34.66.94.12.nip.io,http://34.66.94.12,http://discovery.34.66.94.12.nip.io
# BASE_URL=http://hub.34.66.94.12.nip.io

DASH_ADMIN_USER=admin
# Local dev only — remove or leave empty in production
DASH_ADMIN_PASS=changeme
# Production: bcrypt hash only (never commit plain password)
# Generate: php -r "echo password_hash('YOUR_STRONG_PASSWORD', PASSWORD_BCRYPT), PHP_EOL;"
# DASH_ADMIN_PASS_HASH=$2y$10$...

MOBILE_JWT_SECRET=dev_only_change_before_production_use_64_hex_chars_minimum________
# Production: openssl rand -hex 32

# --- Google Analytics (optional) ---
GA_PROPERTY_ID=
# Path relative to ulndash/backend/ (file must exist on disk inside the container mount)
GA_CREDENTIALS_PATH=service-account.json

# --- Firebase Cloud Messaging (admin mobile push alerts) ---
# Enable Firebase Cloud Messaging API on the GCP project; use a service account JSON.
# Place the file at /opt/ulnovatech/secrets/service-account.json on the VM and copy or
# symlink into public_html/ulndash/backend/service-account.json before deploy (see DEPLOY_ORACLE.md).
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=service-account.json
# Falls back to GA_CREDENTIALS_PATH when FCM_CREDENTIALS_PATH is unset

# --- Flutterwave (portfolio payments) ---
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
