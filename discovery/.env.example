# =============================================================================
# Single project env file — copy to `.env` at this repo root only.
# Do NOT duplicate into apps/dashboard/.env.local
#
# API keys (Places, CSE, Bing, Meta): Settings → API credentials in the UI.
# Env fallbacks below are optional (CI/production secrets injection only).
# =============================================================================

# --- Required ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/agency_platform
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev auth (NEVER true in production)
ALLOW_DEV_AUTH=true

# Local dev only: drain pipeline inside Next.js (not for production)
# INLINE_PIPELINE=true

# --- Storage ---
STORAGE_LOCAL_PATH=./storage/uploads

# --- Acquisition mode & budget caps (or edit in Settings UI) ---
ACQUISITION_MODE=standard
PLACES_MONTHLY_CAP=150
CSE_DAILY_CAP=100
BING_DAILY_CAP=50
META_GRAPH_DAILY_CAP=50
BROWSER_DAILY_CAP=10
CUSTOM_SCRAPE_DAILY_CAP=50

# --- Optional feature flags ---
# BROWSER_AUTOMATION_ENABLED=true
# CUSTOM_SCRAPE_ENABLED=true

# --- Optional: API key env fallbacks (prefer Settings UI) ---
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_API_KEYS=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# BING_SEARCH_KEY=
# META_GRAPH_API_TOKEN=

# --- Auth (production) ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/ops
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/ops

# --- Observability (optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Cron (production HTTP polls) ---
CRON_SECRET=

# --- Gmail OAuth (optional) ---
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
